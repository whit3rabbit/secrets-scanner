{
  "name": "@whit3rabbit/rsecrets-scanner",
  "version": "0.2.1",
  "description": "Native Node.js bindings for secrets-scanner.",
  "license": "MIT",
  "type": "commonjs",
  "main": "./index.js",
  "types": "./public.d.ts",
  "exports": {
    ".": {
      "types": "./public.d.ts",
      "require": "./index.js",
      "default": "./index.js"
    }
  },
  "files": [
    "index.js",
    "public.d.ts",
    "lib",
    "*.node",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "napi build --release",
    "build:debug": "napi build",
    "build:ci": "napi build --release --platform --no-js",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build && npm test && npm run typecheck",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "napi": {
    "binaryName": "secrets_scanner_core"
  },
  "devDependencies": {
    "@napi-rs/cli": "3.7.2",
    "@types/node": "25.9.3",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
